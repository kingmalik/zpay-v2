# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://app:secret@db:5432/appdb

# ── Security (REQUIRED in production) ────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
ZPAY_SECRET_KEY=generate-a-strong-random-string
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ZPAY_PASSWORD_HASH_MALIK=bcrypt-hash-here
ZPAY_PASSWORD_HASH_MOM=bcrypt-hash-here
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ZPAY_ENCRYPTION_KEY=fernet-key-here
# Set to 1 for production (enables HTTPS redirect, secure cookies, HSTS)
ZPAY_PRODUCTION=0

# ── External services ────────────────────────────────────────
FIRSTALT_USERNAME=your_firstalt_username
FIRSTALT_PASSWORD=your_firstalt_password
FIRSTALT_USER_POOL_ID=your_cognito_user_pool_id
FIRSTALT_CLIENT_ID=your_cognito_client_id
FIRSTALT_STATE_CODE=your_state_code
GMAIL_USER_ACUMEN=your_acumen_gmail@gmail.com
GMAIL_APP_PASSWORD_ACUMEN=your_gmail_app_password
GMAIL_USER_MAZ=your_maz_gmail@gmail.com
GMAIL_APP_PASSWORD_MAZ=your_gmail_app_password
EVERDRIVEN_USERNAME=your_everdriven_email@gmail.com
EVERDRIVEN_PASSWORD=your_everdriven_password
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
