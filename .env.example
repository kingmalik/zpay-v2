# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://app:secret@db:5432/appdb

# ── Security (REQUIRED in production) ────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
ZPAY_SECRET_KEY=generate-a-strong-random-string
# HMAC secret for driver-facing public scorecard links (Phase 9).
# Tokens expire after 14 days. Changing this key invalidates all existing links.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SCORECARD_HMAC_SECRET=generate-a-strong-random-string
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt()).decode())"
ZPAY_PASSWORD_HASH_MALIK=bcrypt-hash-here
ZPAY_PASSWORD_HASH_MOM=bcrypt-hash-here
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ZPAY_ENCRYPTION_KEY=fernet-key-here
# Set to 1 for production (enables HTTPS redirect, secure cookies, HSTS)
ZPAY_PRODUCTION=0

# ── External services ────────────────────────────────────────
FIRSTALT_USERNAME=your_firstalt_username
FIRSTALT_PASSWORD=your_firstalt_password
FIRSTALT_USER_POOL_ID=your_cognito_user_pool_id
FIRSTALT_CLIENT_ID=your_cognito_client_id
FIRSTALT_STATE_CODE=your_state_code
GMAIL_USER_ACUMEN=your_acumen_gmail@gmail.com
GMAIL_APP_PASSWORD_ACUMEN=your_gmail_app_password
GMAIL_USER_MAZ=your_maz_gmail@gmail.com
GMAIL_APP_PASSWORD_MAZ=your_gmail_app_password
EVERDRIVEN_USERNAME=your_everdriven_email@gmail.com
EVERDRIVEN_PASSWORD=your_everdriven_password
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Trip Acceptance Monitor ───────────────────────────────────
MONITOR_ENABLED=0
MONITOR_DRY_RUN=0
MONITOR_INTERVAL_MINUTES=15
MONITOR_START_HOUR=4
MONITOR_END_HOUR=22
MONITOR_REMINDER_WINDOW_MINUTES=75
MONITOR_TIMEZONE=America/Los_Angeles
# Admin voice-call quiet hours (PT). Calls suppressed; SMS still goes through.
ADMIN_QUIET_HOUR_START=22
ADMIN_QUIET_HOUR_END=7
# Only escalate start-stage to admin when trip is actually overdue (default: true).
# Prevents false alarms for ED drivers who don't tap Start in the app.
MONITOR_START_OVERDUE_ONLY=true
MONITOR_START_OVERDUE_GRACE_MINUTES=10

# ── Twilio (SMS + calls + WhatsApp) ──────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# WhatsApp sender number from Twilio (format: +1XXXXXXXXXX — no whatsapp: prefix needed)
TWILIO_WHATSAPP_NUMBER=+1XXXXXXXXXX
# Operator phone to receive proactive WhatsApp alerts (format: +1XXXXXXXXXX)
OPERATOR_WHATSAPP_PHONE=+1XXXXXXXXXX

# ── Admin alerts ───────────────────────────────────────────
ADMIN_PHONE=+1XXXXXXXXXX
# Public URL of the Railway backend — required for Twilio voice-gather Gather callback
# and ElevenLabs audio serving. Set to your Railway service URL.
# Example: https://zpay-backend.up.railway.app
BACKEND_PUBLIC_URL=

# ── Severity-tier push notifications (Phase 3) ─────────────
# ntfy topic for Z-Pay ops alerts (LOW/MED/HIGH/CRITICAL tier push).
# Separate from HEALTH_NTFY_TOPIC so health pings and driver ops don't mix.
# Falls back to HEALTH_NTFY_TOPIC when unset. Get a free topic at ntfy.sh.
ZPAY_NTFY_TOPIC=zpay-ops-alerts
# OPS_NTFY_TOPIC is the ops_alert.py env var name — alias for ZPAY_NTFY_TOPIC
OPS_NTFY_TOPIC=zpay-ops-alerts
# ntfy topic for system health monitor (health_monitor.py)
HEALTH_NTFY_TOPIC=zpay-health
# ntfy server base URL — defaults to https://ntfy.sh (override if self-hosting)
HEALTH_NTFY_SERVER=https://ntfy.sh
# Discord webhook URL — paper trail for all severity tiers (always fires).
# Create in Discord: Server Settings > Integrations > Webhooks > New Webhook.
DISCORD_WEBHOOK_URL=

# ── WhatsApp Operator Features ─────────────────────────────
# Set to 1 to enable the daily 8am financial intelligence report
WHATSAPP_INTEL_ENABLED=0

# ── Onboarding automation ───────────────────────────────────
PRIORITY_EMAIL=              # Email address for Priority transport contact
BRANDON_EMAIL=               # Email address for Brandon at FirstAlt/Acumen
DONNA_EMAIL=                 # Donna's email at Concentra (drug testing clinic contact)
DONNA_PHONE=                 # Donna's phone number at Concentra
CONCENTRA_ADDRESS=           # Concentra clinic address (shown to drivers in the join portal)
FRONTEND_URL=                # Public URL of the Next.js frontend (e.g. https://frontend-ruddy-ten-82.vercel.app)
ADOBE_SIGN_ENABLED=0         # S6: partner contract defaults to the free internal typed-name e-sign; set to "1" (with the key below) to use paid Adobe Sign instead
ADOBE_SIGN_INTEGRATION_KEY=  # Adobe Sign integration key for sending envelopes (paid Acrobat Sign Solutions tier — optional, requires ADOBE_SIGN_ENABLED=1 too)
ADOBE_SIGN_WEBHOOK_KEY=      # Optional but recommended — set to your Adobe Sign Client ID to verify webhook authenticity
ADOBE_SIGN_CONSENT_WEB_FORM_URL=  # Public Adobe Sign Web Form URL for drug-test consent (free path — preferred over API key)
ZPAY_ALLOW_DEV_TOOLS=0       # Dev-only onboarding backdoors (token=="dev", dev-skip-step/-all) — also requires non-production (see routes/onboarding.py _dev_tools_allowed())
ONBOARDING_AUTOSEND=0        # S6: auto-email/SMS the driver their training/contract portal link once they reach that step. Default OFF = dry-run/log only (standing law: no driver-facing sends without approval)
ED_COMPLIANCE_SYNC=0         # S6: EverDriven compliance sync background thread (services/everdriven_compliance.py) — built but never started before; opt in deliberately

# ── First Advantage BGC (FA onboarding — optional, enhances step 3) ─
# Apply at fadv.com/integrations-and-apis/ — requires business account
# If not set, FADV BGC step is skipped and BGC is fully manual via Brandon email
FADV_CLIENT_ID=              # First Advantage OAuth client ID
FADV_CLIENT_SECRET=          # First Advantage OAuth client secret
FADV_BASE_URL=https://api.fadv.com  # Override only if FADV gives you a different base URL

# ── Contractor Compliance (ED onboarding — document monitoring) ──────
# Required to enable real-time document monitoring for EverDriven drivers
# Without this, step 1 invite still works — only the sync polling is skipped
# Get credentials from your Contractor Compliance account manager
CONTRACTOR_COMPLIANCE_API_KEY=   # CC API key (gated — requires CC account)
CONTRACTOR_COMPLIANCE_BASE_URL=https://app.contractorcompliance.io/api

# ── Scorecard cron — Phase 10 ────────────────────────────────────────────────
# Weekly scorecard SMS + email to all active drivers (Sunday 8 PM PT).
#
# Two-flag system — both must be set deliberately:
#
# SCORECARD_CRON_ENABLED=1   → cron loop runs; scorecards computed + written to
#                               scorecard_cache for admin view. NO driver contact.
#                               Use this for data-quality / validation phase.
#
# SCORECARD_SEND_ENABLED=1   → (requires CRON_ENABLED=1 too) enables actual SMS
#                               + email delivery to drivers. Only flip this after
#                               you've confirmed cron is computing correct data.
#
# Safe default is both "0". Flip CRON first, validate data for a week, then SEND.
SCORECARD_CRON_ENABLED=0
SCORECARD_SEND_ENABLED=0

# ── Master Ledger Drive sync — restoration truth ──────────────────────────────
# Writes 3 CSVs to Google Drive every Monday 9 AM PT (Wheels of Unity /
# Z-Pay Reference/). Drive = restoration fallback if prod DB is wiped.
# Set to "1" on Railway only when MONITOR_ENABLED=1 (same scheduler).
# Manual trigger: python3 scripts/sync_master_ledger.py
MASTER_LEDGER_CRON_ENABLED=0
# Override only if Drive mount path changes (default: ~/Library/CloudStorage/...)
# DRIVE_MOUNT_PATH=

# ── Maz Drive archive — payroll xlsx backup on approval ───────────────────────
# On every Maz batch approval, Z-Pay uploads the payroll xlsx to
# Google Drive (Master/Maz/Z-Pay Outputs/) and stores the URL in the DB.
#
# Step 1: Re-run get_gmail_token.py for the "maz" account with the updated
#         SCOPES list that includes drive.file (the script already has this
#         in the drive_archive.py module — pass the scope list manually when
#         running the flow, or use scripts/get_drive_token_maz.py).
# Step 2: Set the three env vars below in Railway prod.
GOOGLE_DRIVE_REFRESH_TOKEN_MAZ=  # refresh token with Gmail+Drive scopes for noreply.mazpay@gmail.com
# Optional: hard-code the Drive folder ID for Z-Pay Outputs to skip the folder lookup
# Leave blank — auto-discovered on first run and logged to Railway logs.
MAZ_PAYROLL_DRIVE_FOLDER_ID=
