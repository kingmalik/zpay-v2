# -------------------------
# Python
# -------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyd
*.pdb
*.egg-info/
*.egg
*.log

# Virtual environments
.venv/
venv/
env/

# Byte-compiled
*.py[co]

# -------------------------
# FastAPI / Uvicorn / Temp
# -------------------------
*.db
*.sqlite3
instance/
*.pid
temp/
tmp/
*.bak
*.cache
.cache/

# Uploaded payroll files
/tmp/payroll_uploads/
*/uploads/
uploads/

# Ignore everything inside data/in and data/out
data/in/*
data/out/*

# But keep the directories themselves
!data/in/.gitkeep
!data/out/.gitkeep

# ED schema dump — may contain internal API surface / type descriptions
data/ed_schema_dump.json

# -------------------------
# DB dumps + encrypted backups — NEVER commit these
# Both data/zpay_cloud_seed.sql and data/seed/zpay_seed.sql contained real
# driver PII (names, phones, Paychex codes). Removed 2026-05-03 via git rm --cached.
# History rewrite (git filter-repo) is deferred — scheduled as follow-up task.
# -------------------------
*.sql
*.gpg
*.dump
data/*.sql
data/seed/*.sql

# -------------------------
# Docker
# -------------------------
# Avoid committing local container artifacts
docker-data/
docker-volume/
volumes/
*.tar

# Ignore docker-compose override files
docker-compose.override.yml

# -------------------------
# Environment Files
# -------------------------
.env
.env.*
!.env.example

# -------------------------
# Node / React Frontend
# -------------------------
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-lock.yaml

# -------------------------
# VSCode / Editors
# -------------------------
.vscode/
.idea/
*.swp
*.swo

# -------------------------
# Mac / OS Files
# -------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# -------------------------
# Cache / Dependencies
# -------------------------
*.mypy_cache/
.mypy_cache/
pytest_cache/
.pytest_cache/
coverage.xml
htmlcov/
.cache/.claude/worktrees/

# One-time token scripts (contain secrets)
scripts/get_token_*.py
.vercel
