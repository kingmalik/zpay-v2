from fastapi import APIRouter, Depends, HTTPException, Request
from typing import Optional, Tuple, List, Dict, Any
from sqlalchemy.orm import Session
from sqlalchemy import text
import logging

from backend.db import get_db

logger = logging.getLogger(__name__)
router = APIRouter()

# Try to import your repo function if it exists
try:
    from backend.repos.rides import person_rides  # adjust if different
    HAS_REPO = True
except Exception:
    HAS_REPO = False
    logger.warning("backend.repos.rides.person_rides not found; will use SQL fallback for /rides/data")

def _row_to_dict(row):
    # ORM instance
    if hasattr(row, "__table__"):
        return {c.name: getattr(row, c.name) for c in row.__table__.columns}
    # Row / RowMapping
    try:
        return dict(row._mapping)
    except Exception:
        return dict(row)

@router.get("/rides/data")
def rides_data(
    request: Request,
    person_id: Optional[int] = None,
    limit: int = 100,
    db: Session = Depends(get_db),
):
try:
    if person_id is not None:
        q = text("""
            SELECT r.*
            FROM ride r
            WHERE r.person_id = :pid
            ORDER BY r.ride_start_ts DESC NULLS LAST, r.ride_id DESC
            LIMIT :lim
        """)
        params = {"pid": person_id, "lim": limit}
    else:
        q = text("""
            SELECT r.*
            FROM ride r
            JOIN person p ON p.person_id = r.person_id
            WHERE p.person_code = :pcode
            ORDER BY r.ride_start_ts DESC NULLS LAST, r.ride_id DESC
            LIMIT :lim
        """)
        params = {"pcode": person_code, "lim": limit}

    res = db.execute(q, params)
    rows = res.fetchall()
    meta = {
        "count": len(rows),
        "selector": "person_id" if person_id is not None else "person_code"
    }
    return {"rows": [_row_to_dict(r) for r in rows], **meta}
except Exception as e:
    logger.exception("SQL fallback for /rides/data failed")
    raise HTTPException(status_code=500, detail=f"/rides/data failed: {e}")