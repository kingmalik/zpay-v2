    request: Request,
    person_id: Optional[int] = None,
    person_code: Optional[str] = None,
    start: date | None = Query(None),
    end: date | None = Query(None),
    db: Session = Depends(get_db),
):
    """
    JSON API the template calls to get rows. If you don't use fetch_rides,
    paste your existing SELECT logic here and set (rows, meta).
    """
    # Validate that exactly one of the two is provided
    if (person_id is None and not person_code) or (person_id is not None and person_code):
        raise HTTPException(
            status_code=400,
            detail="Provide exactly one of person_id or person_code"
        )

