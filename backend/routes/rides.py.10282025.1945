from backend.db.crud import person_rides, person_summary

router = APIRouter(prefix="", tags=["rides"])
templates = Jinja2Templates(directory="templates")


def _row_to_dict(r):
    """Make SQLAlchemy rows JSON-safe (dates/decimals too)."""
    try:
        d = dict(r._mapping)    # SA 1.4/2.0 Row
    except Exception:
        try:
            d = dict(r)
        except Exception:
            d = r
    for k, v in list(d.items()):
        if isinstance(v, (datetime, date)):
            d[k] = v.isoformat()
        elif isinstance(v, Decimal):
            d[k] = float(v)
    return d


@router.get("/rides", include_in_schema=False)
def rides_page(
    request: Request,
    person_id: Optional[int] = None,
    person_code: Optional[str] = None,
    code: str | None = Query(None),
    start: date | None = Query(None),
    end: date | None = Query(None),
):
    """
    Render the Rides page using a Jinja template. The template's JS calls /rides/data
    with the same filters to populate the table.
    """
    return templates.TemplateResponse(
        "rides.html",
        {
            "request": request,
            "person_id": person_id,
            "code": code,
            "start": start.isoformat() if start else "",
            "end": end.isoformat() if end else "",
        },
    )


@router.get("/rides/data")
