
from fastapi import APIRouter, HTTPException
from sqlalchemy.orm import Session
from ..db.db import SessionLocal
from ..db.crud import list_people, person_summary, person_rides

router = APIRouter()

@router.get("/people")
def people():
    db: Session = SessionLocal()
    try:
        return {"ok": True, "people": list_people(db)}
    finally:
        db.close()

@router.get("/summary/person/{person}")
def summary_person(person: str):
    if not person:
        raise HTTPException(status_code=400, detail={"error":"bad_request","message":"person is required"})
    db: Session = SessionLocal()
    try:
        return {"ok": True, "summary": person_summary(db, person)}
    finally:
        db.close()

@router.get("/rides/person/{person}")
def rides_person(person: str, limit: int = 200):
    db: Session = SessionLocal()
    try:
        return {"ok": True, "person": person, "rides": person_rides(db, person, limit=limit)}
    finally:
        db.close()
