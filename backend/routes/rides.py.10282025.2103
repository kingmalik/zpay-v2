# backend/routes/rides.py
from fastapi import APIRouter, Depends, HTTPException, Request
from typing import Optional
from sqlalchemy.orm import Session
from sqlalchemy import text
from backend.db import get_db

router = APIRouter()

def _row_to_dict(row):
    if hasattr(row, "__table__"):
        return {c.name: getattr(row, c.name) for c in row.__table__.columns}
    try:
        return dict(row._mapping)
    except Exception:
        return dict(row)

@router.get("/rides/data")
def rides_data(
    request: Request,
    person_id: Optional[int] = None,
    limit: int = 100,
    db: Session = Depends(get_db),
):
    # require person_id (since there's no person_code in your schema)
    if person_id is None:
        raise HTTPException(status_code=400, detail="person_id is required")

    # query using your actual column names
    q = text("""
        SELECT r.*
        FROM ride r
        WHERE r.person_id = :pid
        ORDER BY r.ride_start_ts DESC NULLS LAST, r.ride_id DESC
        LIMIT :lim
    """)
    rows = db.execute(q, {"pid": person_id, "lim": limit}).fetchall()

    # optional: 404 if no rides
    if not rows:
        raise HTTPException(status_code=404, detail=f"No rides for person_id={person_id}")

    return {"rows": [_row_to_dict(r) for r in rows], "count": len(rows), "selector": "person_id"}
