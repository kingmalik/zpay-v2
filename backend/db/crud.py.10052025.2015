
from __future__ import annotations
import os
from typing import Any, Dict, List, Tuple, Optional

from sqlalchemy import (
    select, func, text, MetaData, Table, insert, inspect as sa_inspect, Column
)
from sqlalchemy.exc import IntegrityError
from sqlalchemy.orm import Session

# Import models (works whether called from package or app root)
try:
    from .models import Person, Ride
except Exception:  # fallback
    from backend.db.models import Person, Ride


CREATE_MISSING_PERSONS = os.getenv("CREATE_MISSING_PERSONS", "1").lower() in {"1","true","yes","on"}


# ----------------- helpers -----------------
def _norm_str(s: Any) -> Optional[str]:
    if s is None:
        return None
    t = str(s).strip()
    return t if t else None

def _get_person_row_by_name(db: Session, name: Optional[str]):
    name = _norm_str(name)
    if not name:
        return None
    return db.execute(
        select(Person.person_id, Person.full_name)
        .where(func.lower(Person.full_name) == func.lower(name))
        .limit(1)
    ).first()

def _get_person_row_by_id(db: Session, pid: Optional[int]):
    if pid is None:
        return None
    return db.execute(
        select(Person.person_id, Person.full_name)
        .where(Person.person_id == pid)
        .limit(1)
    ).first()

def _ensure_person_id(db: Session, person_name: Optional[str], _code_unused: Optional[str]) -> Optional[int]:
    row = _get_person_row_by_name(db, person_name)
    if row:
        return int(row[0])

    name = _norm_str(person_name)
    if not name or not CREATE_MISSING_PERSONS:
        return None

    ins = text("INSERT INTO person (full_name) VALUES (:full_name) RETURNING person_id")
    new_row = db.execute(ins, {"full_name": name}).first()
    return int(new_row[0]) if new_row else None

def _reflect_ride(db: Session) -> Table:
    md = MetaData()
    # reflect the exact DB table; no reliance on ORM mapping (which may mismatch)
    return Table("ride", md, autoload_with=db.get_bind())

def _ride_column_map(ride_tbl: Table) -> Dict[str, str]:
    """
    Return a mapping of logical keys -> actual column names that exist in DB.
    Logical keys: ride_id, person_id, date, key, name, miles, gross, net_pay, code, source_file, source_page
    """
    cols = {c.name.lower(): c.name for c in ride_tbl.columns}
    def pick(*candidates: str) -> Optional[str]:
        for cand in candidates:
            if cand in cols:
                return cols[cand]
        return None

    return {
        "ride_id":   pick("ride_id", "id"),
        "person_id": pick("person_id", "personid", "employee_id"),
        "date":      pick("date", "service_date", "ride_date", "trip_date", "work_date"),
        "key":       pick("key", "trip_key", "job_key", "ticket", "reference", "ref"),
        "name":      pick("name", "trip_name", "description", "route_name", "routename"),
        "miles":     pick("miles", "distance"),
        "gross":     pick("gross", "amount", "pay_gross", "total", "payment"),
        "net_pay":   pick("net_pay", "netpay", "pay_net", "net"),
        "code":      pick("code", "employee_code", "driver_code", "person_code"),
        "source_file": pick("source_file", "sourcefile", "src_file", "source"),
        "source_page": pick("source_page", "sourcepage", "src_page", "page"),
    }

def _value_or_none(rows_val: Any):
    return rows_val if rows_val is not None else None


# ----------------- upload path -----------------
def bulk_insert_rides(db: Session, rows: List[Dict[str, Any]]) -> Tuple[int, int]:
    """
    Reflects the `ride` table and inserts rows using only columns that exist.
    Never references non-existent columns like ride.date or person.code.
    """
    ride_tbl = _reflect_ride(db)
    cmap = _ride_column_map(ride_tbl)

    inserted, skipped = 0, 0
    for r in rows:
        pid = _ensure_person_id(db, r.get("Person"), r.get("Code"))
        if pid is None:
            skipped += 1
            continue

        values: Dict[str, Any] = {}

        # mandatory: person_id
        if cmap["person_id"]:
            values[cmap["person_id"]] = pid
        else:
            # can't insert without a person_id column
            skipped += 1
            continue

        # optional columns
        if cmap["date"]:
            dt = r.get("Date")
            values[cmap["date"]] = (dt.date() if hasattr(dt, "date") else dt)

        if cmap["key"]:
            values[cmap["key"]] = _norm_str(r.get("Key"))

        if cmap["name"]:
            values[cmap["name"]] = _norm_str(r.get("Name"))

        if cmap["miles"]:
            values[cmap["miles"]] = r.get("Miles")

        if cmap["gross"]:
            values[cmap["gross"]] = r.get("Gross")

        if cmap["net_pay"]:
            values[cmap["net_pay"]] = r.get("Net Pay")

        if cmap["code"]:
            values[cmap["code"]] = _norm_str(r.get("Code"))

        if cmap["source_file"]:
            values[cmap["source_file"]] = _norm_str(r.get("source_file"))

        if cmap["source_page"]:
            values[cmap["source_page"]] = r.get("source_page")

        try:
            db.execute(insert(ride_tbl).values(**values))
            db.commit()
            inserted += 1
        except IntegrityError:
            db.rollback()
            skipped += 1

    return inserted, skipped


# ----------------- summary compatibility -----------------
def list_people(db: Session) -> List[str]:
    rows = db.execute(
        select(Person.full_name).order_by(Person.full_name.asc())
    ).all()
    return [r[0] for r in rows if r[0]]

def _resolve_person_row(db: Session, person: str | int):
    try:
        pid = int(str(person))
        row = _get_person_row_by_id(db, pid)
        if row:
            return row
    except ValueError:
        pass
    return _get_person_row_by_name(db, str(person))

def person_summary(db: Session, person: str | int) -> Dict[str, Any]:
    ride_tbl = _reflect_ride(db)
    cmap = _ride_column_map(ride_tbl)

    prow = _resolve_person_row(db, person)
    if not prow:
        return {
            "person": str(person),
            "person_id": None,
            "rides_count": 0,
            "total_miles": 0.0,
            "total_gross": 0.0,
            "total_net_pay": 0.0,
            "by_day": [],
        }

    pid, pname = int(prow[0]), prow[1]

    # Build aggregate selects dynamically
    c_pid = ride_tbl.c[cmap["person_id"]]
    c_rid = ride_tbl.c[cmap["ride_id"]] if cmap["ride_id"] else func.null()
    c_miles = ride_tbl.c[cmap["miles"]] if cmap["miles"] else func.null()
    c_gross = ride_tbl.c[cmap["gross"]] if cmap["gross"] else func.null()
    c_net   = ride_tbl.c[cmap["net_pay"]] if cmap["net_pay"] else func.null()
    c_date  = ride_tbl.c[cmap["date"]] if cmap["date"] else None

    totals_q = select(
        func.count(c_rid) if cmap["ride_id"] else func.count(),
        func.coalesce(func.sum(c_miles), 0.0) if cmap["miles"] else func.cast(0.0, func.float()),
        func.coalesce(func.sum(c_gross), 0.0) if cmap["gross"] else func.cast(0.0, func.float()),
        func.coalesce(func.sum(c_net), 0.0) if cmap["net_pay"] else func.cast(0.0, func.float()),
    ).where(c_pid == pid)

    rides_count, total_miles, total_gross, total_net = db.execute(totals_q).one()

    by_day: List[Dict[str, Any]] = []
    if c_date is not None:
        daily_q = (
            select(
                c_date,
                func.coalesce(func.sum(c_miles), 0.0) if cmap["miles"] else func.cast(0.0, func.float()),
                func.coalesce(func.sum(c_gross), 0.0) if cmap["gross"] else func.cast(0.0, func.float()),
                func.coalesce(func.sum(c_net), 0.0) if cmap["net_pay"] else func.cast(0.0, func.float()),
                func.count(c_rid) if cmap["ride_id"] else func.count(),
            )
            .where(c_pid == pid)
            .group_by(c_date)
            .order_by(c_date.asc())
        )
        rows = db.execute(daily_q).all()
        for d in rows:
            by_day.append({
                "date": (str(d[0]) if d[0] is not None else None),
                "miles": float(d[1] or 0.0),
                "gross": float(d[2] or 0.0),
                "net_pay": float(d[3] or 0.0),
                "rides": int(d[4] or 0),
            })

    return {
        "person": pname,
        "person_id": pid,
        "rides_count": int(rides_count or 0),
        "total_miles": float(total_miles or 0.0),
        "total_gross": float(total_gross or 0.0),
        "total_net_pay": float(total_net or 0.0),
        "by_day": by_day,
    }

def person_rides(db: Session, person: str | int, limit: int = 200) -> List[Dict[str, Any]]:
    ride_tbl = _reflect_ride(db)
    cmap = _ride_column_map(ride_tbl)

    prow = _resolve_person_row(db, person)
    if not prow:
        return []
    pid = int(prow[0])

    c_pid = ride_tbl.c[cmap["person_id"]]
    cols = []
    def add_col(logical_key: str):
        cname = cmap[logical_key]
        cols.append(ride_tbl.c[cname] if cname else func.null().label(logical_key))

    # choose a consistent projection
    add_col("ride_id")
    add_col("date")
    add_col("key")
    add_col("name")
    add_col("miles")
    add_col("gross")
    add_col("net_pay")
    add_col("code")
    add_col("source_file")
    add_col("source_page")

    # order by date then key if available
    order_cols = []
    if cmap["date"]:
        order_cols.append(ride_tbl.c[cmap["date"]].asc())
    if cmap["key"]:
        order_cols.append(ride_tbl.c[cmap["key"]].asc())

    q = select(*cols).where(c_pid == pid)
    if order_cols:
        q = q.order_by(*order_cols)
    q = q.limit(limit)

    rows = db.execute(q).all()

    out: List[Dict[str, Any]] = []
    for row in rows:
        # row ordering follows add_col list
        out.append({
            "ride_id": row[0],
            "date": (str(row[1]) if row[1] is not None else None),
            "key": row[2],
            "name": row[3],
            "miles": float(row[4]) if row[4] is not None else None,
            "gross": float(row[5]) if row[5] is not None else None,
            "net_pay": float(row[6]) if row[6] is not None else None,
            "code": row[7],
            "source_file": row[8],
            "source_page": row[9],
        })
    return out
