
from __future__ import annotations
import os
from typing import Any, Dict, List, Tuple

from sqlalchemy import select, func, text
from sqlalchemy.exc import IntegrityError
from sqlalchemy.orm import Session

# Import models (works whether called from package or app root)
try:
    from .models import Person, Ride
except Exception:  # fallback
    from backend.db.models import Person, Ride


# Toggle: allow auto-create of people by name when not found.
# Safe even if ORM maps a non-existent Person.code, since we insert via raw SQL (no ORM insert).
CREATE_MISSING_PERSONS = os.getenv("CREATE_MISSING_PERSONS", "1").lower() in {"1","true","yes","on"}


# ----------------- helpers -----------------
def _norm_str(s: Any) -> str | None:
    if s is None:
        return None
    t = str(s).strip()
    return t if t else None

def _get_person_row_by_name(db: Session, name: str | None):
    name = _norm_str(name)
    if not name:
        return None
    # Select ONLY columns that we are sure exist
    return db.execute(
        select(Person.person_id, Person.full_name)
        .where(func.lower(Person.full_name) == func.lower(name))
        .limit(1)
    ).first()  # returns Row or None

def _get_person_row_by_id(db: Session, pid: int | None):
    if pid is None:
        return None
    return db.execute(
        select(Person.person_id, Person.full_name)
        .where(Person.person_id == pid)
        .limit(1)
    ).first()

def _ensure_person_id(db: Session, person_name: str | None, _code_unused: str | None) -> int | None:
    """
    Return person_id for the given name; create if allowed.
    Uses raw SQL for INSERT so we never reference a non-existent mapped column.
    """
    row = _get_person_row_by_name(db, person_name)
    if row:
        return int(row[0])

    name = _norm_str(person_name)
    if not name or not CREATE_MISSING_PERSONS:
        return None

    # Insert with raw SQL to avoid ORM trying to include a mapped-but-nonexistent column.
    ins = text("INSERT INTO person (full_name) VALUES (:full_name) RETURNING person_id")
    new_row = db.execute(ins, {"full_name": name}).first()
    # Do not commit yet; caller will commit after adding ride (same transaction)
    return int(new_row[0]) if new_row else None


# ----------------- upload path -----------------
def bulk_insert_rides(db: Session, rows: List[Dict[str, Any]]) -> Tuple[int, int]:
    """
    Inserts parsed rides into existing `ride` table (singular).
    Maps fields from the PDF-normalized dicts.
    Returns (inserted, skipped).
    """
    inserted, skipped = 0, 0
    for r in rows:
        pid = _ensure_person_id(db, r.get("Person"), r.get("Code"))
        if pid is None:
            skipped += 1
            continue

        ride_kwargs: Dict[str, Any] = dict(
            person_id=pid,
            date=(r.get("Date").date() if r.get("Date") is not None else None),
            key=r.get("Key"),
            name=r.get("Name"),
            miles=r.get("Miles"),
            gross=r.get("Gross"),
            net_pay=r.get("Net Pay"),
            source_file=r.get("source_file"),
            source_page=r.get("source_page"),
        )
        # Only set Ride.code if the model actually has it
        if hasattr(Ride, "code"):
            ride_kwargs["code"] = r.get("Code")

        ride = Ride(**ride_kwargs)
        db.add(ride)
        try:
            db.commit()
            inserted += 1
        except IntegrityError:
            db.rollback()
            skipped += 1

    return inserted, skipped


# ----------------- summary compatibility -----------------
def list_people(db: Session) -> List[str]:
    """Return distinct people by full_name, sorted."""
    rows = db.execute(
        select(Person.full_name).order_by(Person.full_name.asc())
    ).all()
    return [r[0] for r in rows if r[0]]

def _resolve_person_row(db: Session, person: str | int):
    # numeric? treat as id
    try:
        pid = int(str(person))
        row = _get_person_row_by_id(db, pid)
        if row:
            return row
    except ValueError:
        pass
    # otherwise treat as name
    return _get_person_row_by_name(db, str(person))

def person_summary(db: Session, person: str | int) -> Dict[str, Any]:
    """
    Accepts a person name or id. Returns totals and per-day breakdown.
    Output keys: person, person_id, rides_count, total_miles, total_gross, total_net_pay, by_day[]
    """
    prow = _resolve_person_row(db, person)
    if not prow:
        return {
            "person": str(person),
            "person_id": None,
            "rides_count": 0,
            "total_miles": 0.0,
            "total_gross": 0.0,
            "total_net_pay": 0.0,
            "by_day": [],
        }

    pid, pname = int(prow[0]), prow[1]

    rides_count, total_miles, total_gross, total_net = db.execute(
        select(
            func.count(Ride.ride_id),
            func.coalesce(func.sum(Ride.miles), 0.0),
            func.coalesce(func.sum(Ride.gross), 0.0),
            func.coalesce(func.sum(Ride.net_pay), 0.0),
        ).where(Ride.person_id == pid)
    ).one()

    daily = db.execute(
        select(
            Ride.date,
            func.coalesce(func.sum(Ride.miles), 0.0),
            func.coalesce(func.sum(Ride.gross), 0.0),
            func.coalesce(func.sum(Ride.net_pay), 0.0),
            func.count(Ride.ride_id),
        )
        .where(Ride.person_id == pid)
        .group_by(Ride.date)
        .order_by(Ride.date.asc())
    ).all()

    by_day = [{
        "date": (str(d[0]) if d[0] is not None else None),
        "miles": float(d[1] or 0.0),
        "gross": float(d[2] or 0.0),
        "net_pay": float(d[3] or 0.0),
        "rides": int(d[4] or 0),
    } for d in daily]

    return {
        "person": pname,
        "person_id": pid,
        "rides_count": int(rides_count or 0),
        "total_miles": float(total_miles or 0.0),
        "total_gross": float(total_gross or 0.0),
        "total_net_pay": float(total_net or 0.0),
        "by_day": by_day,
    }

def person_rides(db: Session, person: str | int, limit: int = 200) -> List[Dict[str, Any]]:
    """Accepts a person name or id. Returns list of ride rows (dicts) ordered by date, key."""
    prow = _resolve_person_row(db, person)
    if not prow:
        return []
    pid = int(prow[0])

    rows = db.execute(
        select(Ride)
        .where(Ride.person_id == pid)
        .order_by(Ride.date.asc(), Ride.key.asc())
        .limit(limit)
    ).scalars().all()

    out: List[Dict[str, Any]] = []
    for r in rows:
        out.append({
            "ride_id": r.ride_id,
            "date": (str(r.date) if r.date else None),
            "key": r.key,
            "name": r.name,
            "miles": (float(r.miles) if r.miles is not None else None),
            "gross": (float(r.gross) if r.gross is not None else None),
            "net_pay": (float(r.net_pay) if r.net_pay is not None else None),
            "code": getattr(r, "code", None),
            "source_file": r.source_file,
            "source_page": r.source_page,
        })
    return out
